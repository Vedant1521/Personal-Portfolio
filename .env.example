# Server-only secret. Do not expose this with NEXT_PUBLIC_.
# Required for /api/groq/chat, /api/groq/speech, and /api/groq/transcribe.
GROQ_API_KEY=your_groq_api_key_here

# Public owner/profile links. These values are visible in the browser.
NEXT_PUBLIC_GITHUB_PROFILE=https://github.com/your-github-username
NEXT_PUBLIC_TWITTER_URL=https://x.com/your-x-username
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-linkedin-username/
NEXT_PUBLIC_PORTFOLIO_URL=https://your-production-domain.com
NEXT_PUBLIC_PORTFOLIO_ALT_URL=https://your-preview-domain.vercel.app
NEXT_PUBLIC_EMAIL=hello@example.com
NEXT_PUBLIC_PHONE="+1 555 000 0000"

# Featured project URLs.
NEXT_PUBLIC_PROJECT_1_URL=https://project-one.example.com
NEXT_PUBLIC_PROJECT_1_GITHUB=https://github.com/your-github-username/project-one
NEXT_PUBLIC_PROJECT_2_URL=https://project-two.example.com
NEXT_PUBLIC_PROJECT_2_GITHUB=https://github.com/your-github-username/project-two
NEXT_PUBLIC_PROJECT_3_URL=https://project-three.example.com
NEXT_PUBLIC_PROJECT_3_GITHUB=https://github.com/your-github-username/project-three
NEXT_PUBLIC_PROJECT_4_URL=https://project-four.example.com
NEXT_PUBLIC_PROJECT_4_GITHUB=https://github.com/your-github-username/project-four

# Optional public API overrides.
NEXT_PUBLIC_GITHUB_API_URL=https://api.github.com
NEXT_PUBLIC_WEATHER_API_URL=https://wttr.in
NEXT_PUBLIC_NOMINATIM_API_URL=https://nominatim.openstreetmap.org
NEXT_PUBLIC_OPENSTREETMAP_URL=https://www.openstreetmap.org
NEXT_PUBLIC_JAMENDO_CLIENT_ID=3dce8b55
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
